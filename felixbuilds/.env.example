# FelixBuilds — Next.js Frontend Environment Variables
# Copy to .env.local and fill in your values.

# Django backend URL (used by both client forms and server API routes)
NEXT_PUBLIC_API_URL=http://localhost:8000
DJANGO_API_URL=http://localhost:8000

# Production:
# NEXT_PUBLIC_API_URL=https://api.felixbuilds.com
# DJANGO_API_URL=https://api.felixbuilds.com

# Google Search Console verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-token-here

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
